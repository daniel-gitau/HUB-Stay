{
  "version": 2,
  "framework": "node",
  "buildCommand": "echo 'No build step required'",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "regions": ["iad1"],
  "functions": {
    "server/server.js": {
      "runtime": "nodejs18.x",
      "maxDuration": 30
    }
  },
  "routes": [
    { "src": "/(.*)", "dest": "/server/server.js" }
  ]
}